generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  plan         String   @default("custom")
  subdomain    String?
  logo         String   @default("")
  primaryColor String   @default("#059669")
  apiKey       String   @default("")
  aiModel      String   @default("llama-3.1-8b-instant")
  aiProvider   String   @default("groq")
  kbThreshold  Int      @default(80)
  ragThreshold Int      @default(72)
  tempQA       Float    @default(0.05)
  tempRAG      Float    @default(0.10)
  tempEscalade Float    @default(0.20)
  chunkSize    Int      @default(500)
  topNChunks   Int      @default(3)
  relanceActive Boolean @default(true)
  siteContext  String   @default("")
  relanceText  String   @default("")
  useVectorRag Boolean  @default(false)
  hfApiKey      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users           User[]
  widgetConfigs   WidgetConfig[]
  kbEntries       KBEntry[]
  clientDocuments ClientDocument[]
  aiUsageLogs     AIUsageLog[]
  conversations   Conversation[]
  messageFeedback MessageFeedback[]
  apiKeys         ApiKey[]
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  role     String @default("client")
  clientId String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model WidgetConfig {
  id                String  @id @default(uuid())
  welcomeTitle      String  @default("Bienvenue !")
  welcomeSub        String  @default("")
  showBrand         Boolean @default(true)
  position          String  @default("right")
  marginBottom      Int     @default(20)
  marginRight       Int     @default(20)
  avatarIcon        String  @default("robot")
  proactiveEnabled  Boolean @default(false)
  autoOpenDelay     Int     @default(5)
  showNotification  Boolean @default(true)
  notificationText  String  @default("")
  sendGreeting      Boolean @default(false)
  scrollTrigger       Int     @default(0)
  exitIntent          Boolean @default(false)
  buttonAnimation     String  @default("pulse")
  buttonLabel         String  @default("")
  buttonLabelDuration Int     @default(8)
  buttonIcon          String  @default("")
  aiColor             String  @default("#7c3aed")
  clientId            String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model KBEntry {
  id            String   @id @default(uuid())
  tag           String   @default("")
  question      String
  alt_questions String   @default("")
  short_resp    String   @default("")
  answer        String
  category      String   @default("")
  keywords      String   @default("")
  priority      Int      @default(5)
  related_tags  String   @default("")
  icon          String   @default("")
  source        String   @default("")
  source_url    String   @default("")
  valid_until   String   @default("")
  clientId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientDocument {
  id                String    @id @default(uuid())
  clientId          String
  originalName      String
  mimeType          String    @default("")
  content           String    @default("")
  fileSize          Int       @default(0)
  description       String    @default("")
  tags              String    @default("")
  category          String    @default("")
  author            String    @default("")
  version           Int       @default(1)
  previousVersionId String    @default("")
  source_url        String    @default("")
  valid_from        DateTime?
  valid_until       DateTime?
  status            String    @default("active")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AIUsageLog {
  id              String   @id @default(uuid())
  clientId        String
  provider        String
  model           String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  createdAt       DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model MessageFeedback {
  id             String   @id @default(uuid())
  clientId       String
  messageId      String
  conversationId String   @default("")
  rating         Int
  question       String
  response       String
  source         String   @default("")
  score          Int      @default(0)
  provider       String   @default("")
  comment        String   @default("")
  pageUrl        String   @default("")
  createdAt      DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id           String   @id @default(uuid())
  clientId     String
  provider     String
  model        String?
  label        String   @default("")
  key          String
  isActive     Boolean  @default(true)
  priority     Int      @default(0)
  monthlyLimit Int      @default(0)
  usedTokens   Int      @default(0)
  lastResetAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, priority])
}

model GlobalConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Conversation {
  id        String   @id @default(uuid())
  title     String   @default("")
  messages  String   @default("[]")
  clientId  String
  ipAddress String   @default("")
  country   String   @default("")
  city      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
